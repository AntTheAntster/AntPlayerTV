<?xml version="1.0" encoding="utf-8"?>
<!--
  v2.0 — focus highlight applied to ExoPlayer controller buttons.
  Default media3 controls have very subtle focus visuals on TV; this
  selector adds a clear filled rounded rectangle + bright outline so the
  focused button is unmistakable from across the room.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#558B5CF6" />
                    <corners android:radius="10dp" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <stroke android:width="3dp" android:color="#FFB39DDB" />
                    <corners android:radius="10dp" />
                    <solid android:color="@android:color/transparent" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#806D28D9" />
            <corners android:radius="10dp" />
        </shape>
    </item>
    <item>
        <color android:color="@android:color/transparent" />
    </item>
</selector>
